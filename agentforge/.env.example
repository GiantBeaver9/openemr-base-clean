# AgentForge configuration — copy to .env and fill in.
# NEVER commit a real .env. See ARCHITECTURE.md "auth model" for the trust boundaries.

# ---- Target: the deployed Clinical Co-Pilot under test ----
AGENTFORGE_TARGET_BASE_URL=https://abundant-art-production-d560.up.railway.app
# How AgentForge authenticates to the target (see HANDOFF.md "target auth").
# Filled in once the recon pass confirms the auth model.
AGENTFORGE_TARGET_AUTH_MODE=session          # session | apikey | none
AGENTFORGE_TARGET_USERNAME=
AGENTFORGE_TARGET_PASSWORD=
AGENTFORGE_TARGET_API_KEY=

# ---- Red Team model (must NOT refuse offensive-security prompts) ----
# Point at a local/open model via an OpenAI-compatible endpoint.
REDTEAM_BASE_URL=http://localhost:11434/v1   # e.g. Ollama
REDTEAM_MODEL=llama3.1:8b
REDTEAM_API_KEY=ollama

# ---- Judge model (INDEPENDENT of the Red Team by design) ----
JUDGE_BASE_URL=https://generativelanguage.googleapis.com
JUDGE_MODEL=gemini-1.5-pro
JUDGE_API_KEY=

# ---- Budget guardrails (Orchestrator enforces these) ----
AGENTFORGE_MAX_USD_PER_RUN=2.00
AGENTFORGE_MAX_ATTEMPTS_PER_CAMPAIGN=50
AGENTFORGE_MAX_TURNS=6
