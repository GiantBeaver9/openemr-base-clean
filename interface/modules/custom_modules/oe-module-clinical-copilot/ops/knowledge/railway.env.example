# Clinical Co-Pilot -- knowledge store (pgvector Postgres) env for a deployed
# instance (Railway shown). Set these on the OpenEMR SERVICE, not the Postgres
# service. Copy the values from your Postgres plugin's "Variables" tab, or use
# Railway reference variables (${{Postgres.VAR}}) so they auto-fill and rotate.
#
# The knowledge store is a SEPARATE database from OpenEMR's MySQL by design --
# PHI never lands here. Do NOT point these at OpenEMR's own database.
#
# ---------------------------------------------------------------------------
# 1) CONNECTION -- pick ONE of the two forms below.
# ---------------------------------------------------------------------------

# Form A (recommended): one URL. Inside a Railway project prefer the PRIVATE URL
# (no egress, no TLS needed). ?sslmode is optional; the module defaults to
# "prefer" (tries TLS, falls back) when absent.
CLINICAL_COPILOT_KNOWLEDGE_DATABASE_URL=${{Postgres.DATABASE_URL}}
#   ...from your laptop / cross-project, use the PUBLIC proxy URL instead:
#   CLINICAL_COPILOT_KNOWLEDGE_DATABASE_URL=postgresql://postgres:PASS@HOST.proxy.rlwy.net:PORT/railway?sslmode=require

# Form B: discrete parts (use INSTEAD of the URL, not alongside -- the URL wins).
#   CLINICAL_COPILOT_KNOWLEDGE_DB_HOST=${{Postgres.PGHOST}}
#   CLINICAL_COPILOT_KNOWLEDGE_DB_PORT=${{Postgres.PGPORT}}
#   CLINICAL_COPILOT_KNOWLEDGE_DB_NAME=${{Postgres.PGDATABASE}}
#   CLINICAL_COPILOT_KNOWLEDGE_DB_USER=${{Postgres.PGUSER}}
#   CLINICAL_COPILOT_KNOWLEDGE_DB_PASSWORD=${{Postgres.PGPASSWORD}}
#   CLINICAL_COPILOT_KNOWLEDGE_DB_SSLMODE=prefer

# Optional: a dedicated INSERT-capable role for the ingestion path, so the
# connection above can be granted SELECT-only. Blank => ingestion reuses it.
#   CLINICAL_COPILOT_KNOWLEDGE_DB_WRITE_USER=kb_writer
#   CLINICAL_COPILOT_KNOWLEDGE_DB_WRITE_PASSWORD=...

# Optional: table name. Default guideline_chunks (must match schema.sql).
#   CLINICAL_COPILOT_KNOWLEDGE_TABLE=guideline_chunks

# ---------------------------------------------------------------------------
# 2) EMBEDDINGS -- powers vector search. Without a key the store still works on
#    full-text search alone; with one, chunks are embedded on write and queries
#    rank by pgvector cosine similarity.
# ---------------------------------------------------------------------------
CLINICAL_COPILOT_GEMINI_API_KEY=your_ai_studio_key
# Optional (defaults shown). EMBED_DIM MUST match the vector(N) width in
# schema.sql (768) -- changing it means recreating the column.
#   CLINICAL_COPILOT_KNOWLEDGE_EMBED_MODEL=text-embedding-004
#   CLINICAL_COPILOT_KNOWLEDGE_EMBED_DIM=768

# ---------------------------------------------------------------------------
# 3) APP-SIDE PREREQ (not an env var): the OpenEMR container image must include
#    the pdo_pgsql PHP extension. OpenEMR's stock image is MySQL-only; see
#    ops/local/knowledge/Dockerfile for the one-line add, and mirror it in your
#    deployed image build. Without it the module cleanly falls back to the
#    offline corpus and never touches this database.
# ---------------------------------------------------------------------------
