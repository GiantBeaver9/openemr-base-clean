{#
# Clinical Co-Pilot -- Week 2 extraction review (verify -> edit -> lock).
#
# The human half of Week 2: every extracted value is shown beside what the
# model proposed, editable until the extraction is locked. Locking commits the
# verified values to the chart and records extraction accuracy (accepted vs
# edited). Autoescape is globally OFF (build-notes.md) -- explicit escaping.
#
# @package   OpenEMR
# @link      https://www.open-emr.org
# @author    Clinical Co-Pilot Team
# @copyright Copyright (c) 2026 OpenEMR Foundation
# @license   https://github.com/openemr/openemr/blob/master/LICENSE GNU General Public License 3
#}
<html>
<head>
    <title>{{ "Verify Extraction — Clinical Co-Pilot"|xlt }}</title>
    {{ setupHeader() }}
    <style>
        .ccp-edited { color: #b8860b; }
        .ccp-model-said { font-size: 0.85em; color: #6c757d; }
        .ccp-cite { font-size: 0.85em; }
        .ccp-source-frame { width: 100%; height: 100%; min-height: 520px; border: 1px solid #ced4da; border-radius: .25rem; background: #fff; }
        .ccp-accuracy { font-variant-numeric: tabular-nums; }
        @media (min-width: 992px) {
            .ccp-review-wrap { height: calc(100vh - 220px); }
            .ccp-pane { height: 100%; overflow-y: auto; }
            .ccp-pdf-pane { position: sticky; top: 0; }
        }
    </style>
</head>
<body class="body_top">
<div class="container-fluid mt-3">

    {% if not found %}
        <div class="alert alert-danger" role="alert">{{ "That extraction could not be found."|xlt }}</div>
    {% else %}

    {% if error %}
        <div class="alert alert-warning" role="alert">{{ "That action could not be completed. Please try again."|xlt }}</div>
    {% endif %}

    <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
            <h3 class="mb-0">{{ "Verify"|xlt }} — {{ doc_type_label|text }}</h3>
            <div class="ccp-model-said">
                {% if model %}{{ "Extracted by"|xlt }} {{ model|text }}{% else %}{{ "Manual entry"|xlt }}{% endif %}
            </div>
        </div>
        <div class="text-right">
            {% if locked %}
                <span class="badge badge-success p-2">{{ "Locked — in chart"|xlt }}</span>
            {% else %}
                <span class="badge badge-warning p-2">{{ "Draft — verifying"|xlt }}</span>
            {% endif %}
            {% if field_accuracy is not null %}
                <div class="ccp-model-said ccp-accuracy mt-1">
                    {{ "Extraction accuracy"|xlt }}: {{ (field_accuracy * 100)|round(1) }}%
                </div>
            {% endif %}
        </div>
    </div>

    {# PHI-mixing guard: a lab report is uploaded onto THIS chart, but the file
       names a patient. If the document-header name/DOB disagree, this may be the
       wrong person's results — a loud, persistent alert on every review load
       (mismatch = danger; could-not-confirm = warning; confirmed = quiet
       reassurance). identity_status is null for non-lab / no-vision drafts. #}
    {% if is_lab and identity_status == 'mismatch' %}
        <div class="alert alert-danger" role="alert">
            <h5 class="alert-heading mb-1"><i class="fa fa-exclamation-triangle mr-1"></i>{{ "Patient identity does not match this chart"|xlt }}</h5>
            <p class="mb-1">{{ "The patient named on this document does not match the chart it is being uploaded onto. These results may belong to a different patient — do NOT lock them until you have confirmed this report is for the correct patient."|xlt }}</p>
            {% if identity_detail %}<div class="small">{{ identity_detail|text }}</div>{% endif %}
        </div>
    {% elseif is_lab and identity_status == 'unknown' %}
        <div class="alert alert-warning" role="alert">
            <i class="fa fa-question-circle mr-1"></i>{{ "The patient identity on this document could not be confirmed against this chart. Verify these results belong to this patient before locking."|xlt }}
            {% if identity_detail %}<div class="small mt-1">{{ identity_detail|text }}</div>{% endif %}
        </div>
    {% elseif is_lab and identity_status == 'match' %}
        <div class="alert alert-success py-2" role="alert">
            <i class="fa fa-check-circle mr-1"></i>{{ "Patient name and date of birth on the document match this chart."|xlt }}
        </div>
    {% endif %}

    {# When extraction found nothing (degraded model, or a page it could not
       read), the reviewer still gets the rows structure to hand-enter against
       the document on the right — not a silent empty screen. #}
    {% if is_lab and fields is empty %}
        <div class="alert alert-info py-2">
            <i class="fa fa-info-circle mr-1"></i>{{ "No lab values were extracted from this document. Enter the results manually below and verify them against the document on the right."|xlt }}
        </div>
    {% endif %}

    {# Two-pane review: extracted rows to verify (left) alongside the source
       document (right), so each value is checked against the page it came from. #}
    <div class="row ccp-review-wrap">
    <div class="col-lg-7 ccp-pane">

    <table class="table table-sm table-bordered">
        <thead class="thead-light">
            <tr>
                <th style="width:2rem">#</th>
                <th>{{ "Field"|xlt }}</th>
                <th>{{ "Verified value"|xlt }}</th>
                {% if is_lab %}<th>{{ "Unit"|xlt }}</th><th>{{ "Range"|xlt }}</th><th>{{ "Flag"|xlt }}</th>{% endif %}
                <th>{{ "Model proposed"|xlt }}</th>
                <th>{{ "Source"|xlt }}</th>
            </tr>
        </thead>
        <tbody>
        {% for f in fields %}
            <tr id="ccp-row-{{ f.id|attr }}" data-field-id="{{ f.id|attr }}">
                <td class="align-middle text-muted">{{ loop.index }}</td>
                <td class="align-middle"><strong>{{ f.field_key|text }}</strong></td>
                <td>
                    {% if locked and not is_elevated %}
                        {{ f.value|text }}
                    {% else %}
                        <form method="POST" action="{{ post_url|attr }}" class="form-inline">
                            {{ csrfToken('default', 'csrf_token_form') }}
                            <input type="hidden" name="action" value="edit">
                            <input type="hidden" name="extraction_id" value="{{ extraction_id|attr }}">
                            <input type="hidden" name="field_id" value="{{ f.id|attr }}">
                            <input type="text" class="form-control form-control-sm mr-1" name="value"
                                   value="{{ f.value|attr }}" style="min-width: 8rem;">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ "Save"|xlt }}</button>
                        </form>
                    {% endif %}
                    {% if f.edited_by_user %}<span class="badge badge-light ccp-edited">{{ "edited"|xlt }}</span>{% endif %}
                </td>
                {% if is_lab %}
                    <td class="align-middle">{{ f.unit|text }}</td>
                    <td class="align-middle">{{ f.ref_range|text }}</td>
                    <td class="align-middle">{{ f.abnormal_flag|text }}</td>
                {% endif %}
                <td class="align-middle ccp-model-said">
                    {% if f.vlm_value is not null %}{{ f.vlm_value|text }}{% else %}—{% endif %}
                </td>
                <td class="align-middle ccp-cite">
                    {% if f.page is not null %}
                        <span title="{{ f.quote|attr }}">
                            <i class="fa fa-file-text-o"></i> {{ "p."|xlt }}{{ f.page|text }}
                        </span>
                    {% else %}
                        <span class="text-muted">{{ "manual"|xlt }}</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr><td colspan="{{ is_lab ? 8 : 5 }}" class="text-muted">{{ "No fields yet."|xlt }}</td></tr>
        {% endfor %}
        </tbody>
    </table>

    {% if is_lab and (not locked or is_elevated) %}
        <div class="card mb-3">
            <div class="card-body py-2">
                <form method="POST" action="{{ post_url|attr }}" class="form-row align-items-end">
                    {{ csrfToken('default', 'csrf_token_form') }}
                    <input type="hidden" name="action" value="add_field">
                    <input type="hidden" name="extraction_id" value="{{ extraction_id|attr }}">
                    <div class="col"><label class="small mb-0">{{ "Test"|xlt }}</label><input type="text" class="form-control form-control-sm" name="field_key" required></div>
                    <div class="col"><label class="small mb-0">{{ "Value"|xlt }}</label><input type="text" class="form-control form-control-sm" name="value"></div>
                    <div class="col"><label class="small mb-0">{{ "Unit"|xlt }}</label><input type="text" class="form-control form-control-sm" name="unit"></div>
                    <div class="col"><label class="small mb-0">{{ "Range"|xlt }}</label><input type="text" class="form-control form-control-sm" name="ref_range"></div>
                    <div class="col"><label class="small mb-0">{{ "Flag"|xlt }}</label><input type="text" class="form-control form-control-sm" name="abnormal_flag"></div>
                    <div class="col-auto"><button type="submit" class="btn btn-sm btn-outline-primary">{{ "Add row"|xlt }}</button></div>
                </form>
            </div>
        </div>
    {% endif %}

    </div>{# /left pane #}

    {# RIGHT: the source document, prominent and scrollable (native PDF viewer),
       always shown so the reviewer reads each value off the page. #}
    <div class="col-lg-5 ccp-pane ccp-pdf-pane">
        <div class="font-weight-bold mb-1 small text-muted">{{ "Source document"|xlt }}</div>
        {% if source_view_url %}
            <iframe class="ccp-source-frame" src="{{ source_view_url|attr }}" title="{{ 'Source document'|attr }}"></iframe>
        {% else %}
            <div class="alert alert-secondary mb-0">{{ "The source document is not available for this extraction (it may not have been stored). Verify the values against your copy."|xlt }}</div>
        {% endif %}
    </div>

    </div>{# /row #}

    <div class="d-flex align-items-center justify-content-between mt-3">
        <a href="{{ patient_url|attr }}" class="btn btn-outline-secondary">
            <i class="fa fa-user mr-1"></i>{{ "Go to patient"|xlt }}
        </a>
        <div>
            {% if not locked %}
                {# Single-quoted attribute: xlj (json_encode) supplies double
                   quotes, which would close a double-quoted attribute early. #}
                <form method="POST" action="{{ post_url|attr }}" class="form-inline d-inline-flex align-items-end"
                      onsubmit='return confirm({{ "Lock these values and write them into the chart?"|xlj }})'>
                    {{ csrfToken('default', 'csrf_token_form') }}
                    <input type="hidden" name="action" value="lock">
                    <input type="hidden" name="extraction_id" value="{{ extraction_id|attr }}">
                    {% if is_lab %}
                        <div class="form-group mb-0 mr-2">
                            <label class="small mb-0 mr-1" for="ccpDrawDate">{{ "Draw date"|xlt }}</label>
                            <input type="date" id="ccpDrawDate" class="form-control form-control-sm"
                                   name="collection_date" value="{{ collection_date|attr }}">
                        </div>
                    {% endif %}
                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-lock mr-1"></i>{{ "Verify & lock"|xlt }}
                    </button>
                </form>
            {% elseif is_elevated %}
                <form method="POST" action="{{ post_url|attr }}" style="display:inline;"
                      onsubmit='return confirm({{ "Unlock this extraction for correction?"|xlj }})'>
                    {{ csrfToken('default', 'csrf_token_form') }}
                    <input type="hidden" name="action" value="unlock">
                    <input type="hidden" name="extraction_id" value="{{ extraction_id|attr }}">
                    <button type="submit" class="btn btn-outline-warning">
                        <i class="fa fa-unlock mr-1"></i>{{ "Unlock to correct"|xlt }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    {% endif %}
</div>
</body>
</html>
